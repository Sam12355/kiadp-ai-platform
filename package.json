{
  "name": "khalifa-knowledge-platform",
  "version": "1.0.0",
  "private": true,
  "description": "AI-powered knowledge platform for the Khalifa International Award for Date Palm and Agricultural Innovation",
  "scripts": {
    "preinstall": "npx -y only-allow pnpm",
    "dev:backend": "pnpm --filter @khalifa/backend dev",
    "dev:worker": "pnpm --filter @khalifa/backend dev:worker",
    "dev:frontend": "pnpm --filter @khalifa/frontend dev",
    "build": "pnpm -r build",
    "build:backend": "pnpm --filter @khalifa/backend build",
    "build:frontend": "pnpm --filter @khalifa/frontend build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "db:migrate": "pnpm --filter @khalifa/backend db:migrate",
    "db:seed": "pnpm --filter @khalifa/backend db:seed",
    "db:studio": "pnpm --filter @khalifa/backend db:studio"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
